{
  "name": "@airbnb-clone/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@airbnb-clone/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@airbnb-clone/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
